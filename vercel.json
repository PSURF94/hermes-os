{
  "framework": null,
  "functions": {
    "api/webhook.py": {
      "maxDuration": 10
    },
    "api/cron_resenha.py": {
      "maxDuration": 30
    },
    "api/cron_selecao.py": {
      "maxDuration": 15
    },
    "api/cron_missoes.py": {
      "maxDuration": 10
    }
  },
  "crons": [
    {
      "path": "/api/cron_resenha",
      "schedule": "40 9 * * *"
    },
    {
      "path": "/api/cron_selecao",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron_missoes",
      "schedule": "0 19 * * *"
    }
  ]
}
